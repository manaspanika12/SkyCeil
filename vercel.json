{
  "framework": "vite",
  "installCommand": "npm ci --include=dev",
  "buildCommand": "npm run build",
  "outputDirectory": "apps/web/dist",
  "rewrites": [
    {
      "source": "/api/socket.io/:path*",
      "destination": "/api/server"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/server"
    }
  ],
  "env": {
    "SKYCEIL_PROVIDER": "mock",
    "SKYCEIL_CORS_ORIGIN": "*",
    "VITE_SKYCEIL_API_URL": "",
    "VITE_SKYCEIL_SOCKET_PATH": "/api/socket.io",
    "VITE_SKYCEIL_SOCKET_TRANSPORTS": "websocket,polling"
  }
}
